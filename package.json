{
  "name": "airbucks",
  "version": "0.1.0",
  "description": "A modern remake of the classic airline tycoon Air Bucks",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c cyan,magenta \"vite\" \"wait-on tcp:5173 && cross-env ELECTRON_ENABLE_LOGGING=1 electron .\"",
    "build": "vite build",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:slow": "cross-env RUN_SLOW_TESTS=1 vitest run --no-file-parallelism src/game/ai.test.ts -t \"long-run invariants\"",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "sim": "vite-node scripts/sim.ts",
    "sweep": "vite-node scripts/sweep.ts",
    "analyze": "vite-node scripts/analyze.ts",
    "pack:win": "vite build && electron-builder --win zip --x64"
  },
  "build": {
    "appId": "com.mattfischer.airbucks",
    "productName": "Air Bucks",
    "files": [
      "electron/**",
      "dist/**"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "zip"
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.6",
    "concurrently": "^9.2.3",
    "cross-env": "^7.0.3",
    "electron": "^39.8.5",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^3.2.6",
    "wait-on": "^8.0.1"
  }
}
